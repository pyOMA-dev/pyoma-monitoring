\draw[help lines, black] ($(hr)-(.5,0)$) -- ($(hr)-(.5,0)-.5*(1.5,1)$);
\draw[help lines, black] ($(hr) +.3*(1.5,1)$)--($(hl) +.3*(1.5,1)$);


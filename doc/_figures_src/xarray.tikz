\draw (vol.center) -- (hol.center) -- (hor.center) -- (hur.center) --(v3.center)(v5.center)-- (vur.center) -- (vul.center) -- (vol.center) -- (vor.center) --(v4.center)(v2.center)-- (hor.center);

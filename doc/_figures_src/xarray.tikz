\foreach \x in {-.5,-.75,...,-2} \draw[help lines, black] ($(hor) +(\x,0)+.4*(1.5,1)$)--($(hor) +(\x,0)+.2*(1.5,1)$)--($(hor) +(\x,-.2)+.2*(1.5,1)$);

\foreach \y in {.5,.75,1,...,3} \draw[help lines, black] ($(hur) +(0,\y)+.4*(1.5,1)$)--($(hur) +(0,\y)+.2*(1.5,1)$)--($(hur) +(-.3,\y)+.2*(1.5,1)$);


\draw (v4.center) -- ($(v4.center)-(.5,0)$) -- ($(v4.center)-(.5,0)+.1*(1.5,1)$) -- ($(v4.center)-(.75,0)+.1*(1.5,1)$) -- ($(v2.center)-(.75,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)$) -- (v2.center);


\node (v4) at ($(vr.center)+.3*(1.5,1)$) {};

\fill[red!50!white] (hr.center)--(hl.center)--(vl.center)--(vr.center)--(v4.center) -- ($(v4.center)-(.5,0)$) -- ($(v4.center)-(.5,0)+.1*(1.5,1)$) -- ($(v4.center)-(.75,0)+.1*(1.5,1)$) -- ($(v2.center)-(.75,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)$) -- (v2.center) --(hr.center);
\draw (hr.center)--(hl.center)--(vl.center)--(vr.center)--(v4.center) -- ($(v4.center)-(.5,0)$) -- ($(v4.center)-(.5,0)+.1*(1.5,1)$) -- ($(v4.center)-(.75,0)+.1*(1.5,1)$) -- ($(v2.center)-(.75,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)-.2*(1.5,1)$) -- ($(v2.center)-(.25,0)$) -- (v2.center) --(hr.center);

\fill[red!50!white] ($(hr) +.2*(1.5,1)$) -- ($(hl) +.2*(1.5,1)$) -- ($(hl) +.4*(1.5,1)$)--($(hr) +.4*(1.5,1)$) -- ($(hr) +.2*(1.5,1)$);
\draw ($(hr) +.2*(1.5,1)$) -- ($(hl) +.2*(1.5,1)$) -- ($(hl) +.4*(1.5,1)$)--($(hr) +.4*(1.5,1)$) -- ($(hr) +.2*(1.5,1)$);

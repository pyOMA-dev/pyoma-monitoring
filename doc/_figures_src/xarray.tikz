\draw[help lines, black] ($(vr)-(.25,0)$) -- ($(vr)-(.25,0)+.3*(1.5,1)$);
\draw[help lines, black] ($(vr)-(.5,0)$) -- ($(vr)-(.5,0)+.3*(1.5,1)$);

